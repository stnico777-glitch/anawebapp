// PostgreSQL (Supabase). Auth users live in auth.users; app profile in public.profiles.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String   @id @db.Uuid
  displayName      String?  @map("display_name")
  avatarUrl        String?  @map("avatar_url")
  isSubscriber     Boolean  @default(false) @map("is_subscriber")
  isAdmin          Boolean  @default(false) @map("is_admin")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  completions               UserDayCompletion[]
  workoutCompletions        UserWorkoutCompletion[]
  prayerCompletions         UserPrayerCompletion[]
  prayerJournalEntries      PrayerJournalEntry[]
  prayerReminders           PrayerReminder[]
  prayerRequestInteractions PrayerRequestInteraction[]
  praiseReportLikes         PraiseReportLike[]
  prayerRequestComments     PrayerRequestComment[]
  praiseReportComments      PraiseReportComment[]
  prayerRequests            PrayerRequest[]
  praiseReports             PraiseReport[]

  @@map("profiles")
}

model WeekSchedule {
  id        String   @id @default(uuid()) @db.Uuid
  weekStart DateTime @map("week_start")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  days ScheduleDay[]

  @@map("week_schedule")
}

model ScheduleDay {
  id              String   @id @default(uuid()) @db.Uuid
  weekScheduleId  String   @map("week_schedule_id") @db.Uuid
  dayIndex        Int      @map("day_index")
  prayerTitle     String?  @map("prayer_title")
  prayerId        String?  @map("prayer_id") @db.Uuid
  workoutTitle    String?  @map("workout_title")
  workoutId       String?  @map("workout_id") @db.Uuid
  affirmationText String?  @map("affirmation_text")
  dayImageUrl     String?  @map("day_image_url")
  dayVideoUrl     String?  @map("day_video_url")
  daySubtext      String?  @map("day_subtext")
  /// Shown on the pre-workout screen before the day video. Falls back to app default when null.
  movementIntroHeadline String? @map("movement_intro_headline")
  /// Supporting line under the headline on the pre-workout screen.
  movementIntroSubtext  String? @map("movement_intro_subtext")

  weekSchedule WeekSchedule        @relation(fields: [weekScheduleId], references: [id], onDelete: Cascade)
  prayer       PrayerAudio?        @relation(fields: [prayerId], references: [id], onDelete: SetNull)
  workout      Workout?            @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  completions  UserDayCompletion[]

  @@unique([weekScheduleId, dayIndex])
  @@map("schedule_day")
}

model UserDayCompletion {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  scheduleDayId   String    @map("schedule_day_id") @db.Uuid
  prayerDone      Boolean   @default(false) @map("prayer_done")
  workoutDone     Boolean   @default(false) @map("workout_done")
  affirmationDone Boolean   @default(false) @map("affirmation_done")
  completedAt     DateTime? @map("completed_at")

  user        Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleDay ScheduleDay @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduleDayId])
  @@map("user_day_completion")
}

model Workout {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  instructor   String?
  duration     Int
  category     String?
  scripture    String?
  videoUrl     String   @map("video_url")
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  completions   UserWorkoutCompletion[]
  scheduleDays  ScheduleDay[]

  @@map("workout")
}

model UserWorkoutCompletion {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workoutId   String   @map("workout_id") @db.Uuid
  completedAt DateTime @default(now()) @map("completed_at")

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@unique([userId, workoutId])
  @@map("user_workout_completion")
}

model PrayerAudio {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  scripture     String?
  audioUrl      String   @map("audio_url")
  duration      Int
  coverImageUrl String?  @map("cover_image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  completions  UserPrayerCompletion[]
  scheduleDays ScheduleDay[]

  @@map("prayer_audio")
}

model UserPrayerCompletion {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  prayerId    String   @map("prayer_id") @db.Uuid
  completedAt DateTime @default(now()) @map("completed_at")

  user   Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayer PrayerAudio @relation(fields: [prayerId], references: [id], onDelete: Cascade)

  @@unique([userId, prayerId])
  @@map("user_prayer_completion")
}

enum PrayerJournalStatus {
  ACTIVE
  ANSWERED
  PAUSED
}

enum PrayerReminderCadence {
  DAILY
  WEEKLY
}

model PrayerJournalEntry {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  title      String?
  content    String
  tags       Json                @default("[]")
  status     PrayerJournalStatus @default(ACTIVE)
  answeredAt DateTime?           @map("answered_at")
  answerNote String?             @map("answer_note")
  photos     Json                @default("[]")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  user      Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders PrayerReminder[]

  @@index([userId, status, createdAt])
  @@map("prayer_journal_entry")
}

model PrayerReminder {
  id                   String                @id @default(uuid()) @db.Uuid
  userId               String                @map("user_id") @db.Uuid
  prayerJournalEntryId String?               @map("prayer_journal_entry_id") @db.Uuid
  label                String
  cadence              PrayerReminderCadence
  timeLocal            String                @map("time_local")
  weekDay              Int?                  @map("week_day")
  enabled              Boolean               @default(true)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  user  Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry PrayerJournalEntry? @relation(fields: [prayerJournalEntryId], references: [id], onDelete: SetNull)

  @@index([userId, enabled])
  @@map("prayer_reminder")
}

model DailyVerse {
  id           String   @id @default(uuid()) @db.Uuid
  verseDate    DateTime @unique @map("verse_date")
  reference    String
  text         String
  translation  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("daily_verse")
}

model PrayerRequest {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  authorName String   @map("author_name")
  userId     String?  @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user         Profile?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  interactions PrayerRequestInteraction[]
  comments     PrayerRequestComment[]

  @@map("prayer_request")
}

model PraiseReport {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  authorName String   @map("author_name")
  userId     String?  @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     Profile?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  likes    PraiseReportLike[]
  comments PraiseReportComment[]

  @@map("praise_report")
}

enum PrayerRequestInteractionKind {
  PRAY
  LIKE
  ENCOURAGE
}

model PrayerRequestInteraction {
  id              String                       @id @default(uuid()) @db.Uuid
  prayerRequestId String                       @map("prayer_request_id") @db.Uuid
  userId          String?                      @map("user_id") @db.Uuid
  participantKey  String                       @map("participant_key")
  kind            PrayerRequestInteractionKind
  presetKey       String?                      @map("preset_key")
  message         String?
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  prayerRequest PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user          Profile?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([prayerRequestId, participantKey, kind])
  @@map("prayer_request_interaction")
}

model PraiseReportLike {
  id             String   @id @default(uuid()) @db.Uuid
  praiseReportId String   @map("praise_report_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  participantKey String   @map("participant_key")
  createdAt      DateTime @default(now()) @map("created_at")

  praiseReport PraiseReport @relation(fields: [praiseReportId], references: [id], onDelete: Cascade)
  user         Profile?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([praiseReportId, participantKey])
  @@map("praise_report_like")
}

model PrayerRequestComment {
  id              String   @id @default(uuid()) @db.Uuid
  prayerRequestId String   @map("prayer_request_id") @db.Uuid
  participantKey  String   @map("participant_key")
  userId          String?  @map("user_id") @db.Uuid
  authorName      String   @map("author_name")
  body            String
  createdAt       DateTime @default(now()) @map("created_at")

  prayerRequest PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  user          Profile?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([prayerRequestId, createdAt])
  @@map("prayer_request_comment")
}

model PraiseReportComment {
  id             String   @id @default(uuid()) @db.Uuid
  praiseReportId String   @map("praise_report_id") @db.Uuid
  participantKey String   @map("participant_key")
  userId         String?  @map("user_id") @db.Uuid
  authorName     String   @map("author_name")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  praiseReport PraiseReport @relation(fields: [praiseReportId], references: [id], onDelete: Cascade)
  user         Profile?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([praiseReportId, createdAt])
  @@map("praise_report_comment")
}

model AudioCollectionCard {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  metaLine  String   @map("meta_line")
  imageUrl  String   @map("image_url")
  summary   String
  linkHref  String   @default("/prayer#prayer-library") @map("link_href")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("audio_collection_card")
}

model AudioEssentialTile {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  subtitle  String
  imageUrl  String   @map("image_url")
  linkHref  String   @default("/prayer#prayer-library") @map("link_href")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("audio_essential_tile")
}

model MusicSpotlightEntry {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  artist    String
  coverUrl  String   @map("cover_url")
  listenUrl String?  @map("listen_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("music_spotlight_entry")
}

model MovementLandingCopy {
  id                 String   @id @default("main")
  justStartedTagline String   @map("just_started_tagline")
  quickieIntro       String   @map("quickie_intro")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("movement_landing_copy")
}

model MovementHeroTile {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  subtitle  String
  imageUrl  String   @map("image_url")
  videoUrl  String   @default("") @map("video_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("movement_hero_tile")
}

model MovementQuickieCard {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  metaLine  String   @map("meta_line")
  imageUrl  String   @map("image_url")
  summary   String
  videoUrl  String   @default("") @map("video_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("movement_quickie_card")
}
