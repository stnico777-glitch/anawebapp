{
  "name": "anawebapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "next build",
    "db:migrate:deploy": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "vercel:sync-env": "node scripts/sync-vercel-env.mjs",
    "hero:reverse": "ffmpeg -y -i public/hero-video.mp4 -vf reverse -an -c:v libx264 -preset fast -crf 20 -pix_fmt yuv420p -movflags +faststart public/hero-video-reverse.mp4",
    "hero:poster": "ffmpeg -y -ss 0.25 -i public/hero-video.mp4 -vf \"scale='min(1920,iw)':-2\" -frames:v 1 -q:v 82 public/hero-video-poster.jpg",
    "hero:30fps": "bash scripts/hero-30fps.sh"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.18.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.4.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/blob": "^2.3.1",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
